# AdMob **App** IDs (AdMob → Apps → App settings). Use the ~ form, not the / banner unit form.
# REQUIRED for iOS production ads (Xcode + App Store): set your real iOS App ID. Banner units in code are already production.
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-YOUR_PUBLISHER~YOUR_IOS_APP_SUFFIX
# Android App ID (required for Play builds; sample below is Google demo — replace for production).
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-3940256099942544~3347511713
# Only if you must use Google sample iOS App ID (test ads). Omit in normal Xcode / TestFlight / App Store builds.
# EXPO_PUBLIC_ADMOB_ALLOW_SAMPLE_IOS_APP_ID=1

# Public URL of this policy page after you enable GitHub Pages (update repo/org segment if needed).
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://christianappsfamily.github.io/Proverbs31Prov2/privacy-policy.html

# iOS build number shown in App Store Connect (increment for each upload).
# EXPO_IOS_BUILD_NUMBER=2
